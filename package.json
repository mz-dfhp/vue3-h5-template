{
  "name": "vue3-h5-template",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite --mode dev",
    "build": "vue-tsc -b && vite build --mode dev",
    "build:test": "vue-tsc -b && vite build --mode test",
    "build:dev": "vue-tsc -b && vite build --mode dev",
    "build:prod": "vue-tsc -b && vite build --mode prod",
    "preview": "vite preview",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "simple-git-hooks"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "axios": "^1.15.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "tailwindcss": "^4.2.2",
    "vant": "^4.9.24",
    "vue": "^3.5.32",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.0",
    "eslint-plugin-format": "^2.0.1",
    "lint-staged": "^16.4.0",
    "postcss-px-to-viewport": "^1.1.1",
    "sass": "^1.99.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vue-tsc": "^3.2.6"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
